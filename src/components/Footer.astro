---
const year = new Date().getFullYear();
---

<footer>
  <div class="footer-inner">
    <span>© {year} Fengze Jiang</span>
    <div class="footer-links">
      <a href="https://github.com/jiangfz1997" target="_blank" rel="noopener">GitHub</a>
      <a href="https://linkedin.com/in/" target="_blank" rel="noopener">LinkedIn</a>
      <a href="mailto:jiangfz1997@gmail.com">Email</a>
    </div>
  </div>
</footer>

<style>
  footer {
    border-top: 1px solid var(--color-border);
    padding: 1.5rem;
    color: var(--color-text-muted);
    font-size: 0.875rem;
  }

  .footer-inner {
    max-width: var(--max-width);
    margin: 0 auto;
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .footer-links {
    display: flex;
    gap: 1.25rem;
  }

  .footer-links a {
    color: var(--color-text-muted);
    text-decoration: none;
    transition: color 0.15s;
  }

  .footer-links a:hover {
    color: var(--color-accent);
    text-decoration: none;
  }
</style>
