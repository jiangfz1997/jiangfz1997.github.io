---
interface Props {
  title: string;
  description: string;
  tags: string[];
  slug: string;
  github?: string;
  demo?: string;
  status: 'completed' | 'in-progress' | 'archived';
}

const { title, description, tags, slug, github, demo, status } = Astro.props;

const statusLabel: Record<string, string> = {
  'completed': 'Completed',
  'in-progress': 'In Progress',
  'archived': 'Archived',
};
---

<div class="card">
  <div class="card-top">
    <div class="card-title-row">
      <a href={`/projects/${slug}`} class="card-title">{title}</a>
      <span class:list={['status-badge', status]}>{statusLabel[status]}</span>
    </div>
    <p class="card-desc">{description}</p>
  </div>

  <div class="card-bottom">
    <div class="tags">
      {tags.slice(0, 4).map(tag => <span class="tag">{tag}</span>)}
    </div>
    <div class="card-links">
      {github && (
        <a href={github} target="_blank" rel="noopener" class="icon-link" title="GitHub">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
            <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"/>
          </svg>
        </a>
      )}
      {demo && (
        <a href={demo} target="_blank" rel="noopener" class="icon-link" title="Live demo">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M18 13v6a2 2 0 01-2 2H5a2 2 0 01-2-2V8a2 2 0 012-2h6"/>
            <polyline points="15 3 21 3 21 9"/>
            <line x1="10" y1="14" x2="21" y2="3"/>
          </svg>
        </a>
      )}
      <a href={`/projects/${slug}`} class="detail-link">Details →</a>
    </div>
  </div>
</div>

<style>
  .card {
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    padding: 1.25rem 1.5rem;
    border: 1px solid var(--color-border);
    border-radius: 10px;
    gap: 1rem;
    transition: border-color 0.15s, box-shadow 0.15s, transform 0.15s;
  }

  .card:hover {
    border-color: var(--color-accent);
    box-shadow: 0 4px 24px rgba(109, 133, 245, 0.12);
    transform: translateY(-1px);
  }

  .card-title-row {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    flex-wrap: wrap;
    margin-bottom: 0.4rem;
  }

  .card-title {
    font-size: 1.05rem;
    font-weight: 600;
    color: var(--color-text);
    text-decoration: none;
  }

  .card-title:hover {
    color: var(--color-accent);
    text-decoration: none;
  }

  .status-badge {
    font-size: 0.7rem;
    font-weight: 500;
    padding: 0.15em 0.55em;
    border-radius: 999px;
  }

  .status-badge.completed {
    background: rgba(34, 197, 94, 0.12);
    color: #4ade80;
  }

  .status-badge.in-progress {
    background: rgba(234, 179, 8, 0.12);
    color: #facc15;
  }

  .status-badge.archived {
    background: var(--color-bg-secondary);
    color: var(--color-text-muted);
  }

  .card-desc {
    font-size: 0.9rem;
    color: var(--color-text-muted);
    margin-bottom: 0;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .card-bottom {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .tags {
    display: flex;
    gap: 0.4rem;
    flex-wrap: wrap;
  }

  .card-links {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-shrink: 0;
  }

  .icon-link {
    color: var(--color-text-muted);
    display: flex;
    align-items: center;
    text-decoration: none;
    transition: color 0.15s;
  }

  .icon-link:hover {
    color: var(--color-accent);
    text-decoration: none;
  }

  .detail-link {
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--color-accent);
    white-space: nowrap;
  }
</style>
