---
import Base from '../layouts/Base.astro';
---

<Base title="Resume — Fangzhou Jiang" description="Resume of Fangzhou Jiang, Software Engineer.">
  <div class="resume-wrap">
    <div class="resume-actions">
      <a href="/resume_fangzhou.pdf" download class="btn-download">Download PDF ↓</a>
    </div>
    <iframe src="/resume_fangzhou.pdf" class="resume-frame" title="Resume"></iframe>
  </div>
</Base>

<style>
  .resume-wrap {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 0.75rem;
    padding: 2rem 0;
  }

  .btn-download {
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--color-accent);
    border: 1.5px solid var(--color-accent);
    padding: 0.4rem 1rem;
    border-radius: 6px;
    text-decoration: none;
    transition: background 0.15s;
  }

  .btn-download:hover {
    background: rgba(109, 133, 245, 0.1);
    text-decoration: none;
  }

  .resume-frame {
    width: 100%;
    height: 85vh;
    border: 1px solid var(--color-border);
    border-radius: 8px;
  }
</style>
