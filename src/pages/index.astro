---
import Base from '../layouts/Base.astro';
// import PostCard from '../components/PostCard.astro';
import ProjectCard from '../components/ProjectCard.astro';
import { getCollection } from 'astro:content';
import GameCarousel from '../components/GameCarousel.astro';

// const posts = (await getCollection('blog'))
//   .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
//   .slice(0, 3);

const featuredProjects = (await getCollection('projects'))
  .filter(p => p.data.featured)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<Base title="Fangzhou Jiang">
  <section class="hero">
    <h1>Fangzhou Jiang</h1>
    <p class="hero-tagline">Code, craft, and a curiosity for AI.</p>
    <p class="hero-bio">
      Backend engineer with experience in performance analysis, optimization, and test automation.
      Passionate about backend systems and applying AI to build things that actually work.
    </p>
    <div class="hero-links">
      <a href="/about" class="btn">About me</a>
      <a href="/resume" class="btn btn-outline">Resume</a>
    </div>
  </section>

  <section class="section">
    <div class="section-header">
      <h2 class="section-title">Experience</h2>
    </div>
    <div class="experience-list">
      <div class="experience-item">
        <div class="experience-header">
          <div>
            <span class="experience-company">Netease Games</span>
            <span class="experience-role">Software Engineer in Test</span>
          </div>
          <span class="experience-period">2021 – 2024 · Shanghai, China</span>
        </div>
        <p class="experience-desc">
          <strong>Test</strong> — Owned end-to-end backend performance evaluation on large-scale cloud game servers:
          load testing, disaster recovery, API testing, and test framework maintenance.
        </p>
        <p class="experience-desc">
          <strong>Dev</strong> — Built internal tooling including automated workflows, data monitoring and collection
          pipelines, CI/CD infrastructure, and a workforce efficiency and workflow platform.
        </p>
        <p class="experience-desc">
          <strong>Beyond the code</strong> — Worked across time zones with global studios and took ownership of intern onboarding and mentorship.
        </p>
        <GameCarousel />
      </div>
    </div>
  </section>

  <section class="section">
    <div class="section-header">
      <h2 class="section-title">Featured Personal Projects</h2>
      <a href="/projects" class="section-more">All projects →</a>
    </div>
    <div class="project-grid">
      {featuredProjects.map(p => (
        <ProjectCard
          title={p.data.title}
          description={p.data.description}
          tags={p.data.tags}
          slug={p.slug}
          github={p.data.github}
          demo={p.data.demo}
          status={p.data.status}
        />
      ))}
    </div>
  </section>

  {/* Blog section hidden temporarily
  <section class="section">
    <div class="section-header">
      <h2 class="section-title">Recent Posts</h2>
      <a href="/blog" class="section-more">All posts →</a>
    </div>
    <div class="post-list">
      {posts.map(post => (
        <PostCard
          title={post.data.title}
          description={post.data.description}
          date={post.data.date}
          slug={post.slug}
          tags={post.data.tags}
        />
      ))}
    </div>
  </section>
  */}
</Base>

<style>
  .hero {
    padding: 4rem 0 3rem;
  }

  .hero h1 {
    font-size: 2.5rem;
    margin-bottom: 0.4rem;
  }

  .hero-tagline {
    color: var(--color-accent);
    font-weight: 500;
    font-size: 1rem;
    margin-bottom: 1rem;
    letter-spacing: 0.02em;
  }

  .hero-bio {
    color: var(--color-text-muted);
    font-size: 1.05rem;
    max-width: 520px;
    margin-bottom: 1.75rem;
  }

  .hero-links {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .btn {
    display: inline-block;
    padding: 0.55rem 1.25rem;
    border-radius: 8px;
    font-size: 0.9rem;
    font-weight: 500;
    text-decoration: none;
    background: var(--color-accent);
    color: #fff;
    transition: background 0.15s, transform 0.1s;
  }

  .btn:hover {
    background: var(--color-accent-hover);
    text-decoration: none;
    transform: translateY(-1px);
  }

  .btn-outline {
    background: transparent;
    color: var(--color-accent);
    border: 1.5px solid var(--color-accent);
  }

  .btn-outline:hover {
    background: rgba(109, 133, 245, 0.1);
  }

  .section {
    padding: 2rem 0;
  }

  .section-header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    margin-bottom: 1.25rem;
  }

  .section-title {
    font-size: 1rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-text-muted);
    margin-bottom: 0;
  }

  .section-more {
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--color-accent);
  }

  .project-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
    gap: 1rem;
  }

  .experience-list {
    display: flex;
    flex-direction: column;
    gap: 1.75rem;
  }

  .experience-item {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .experience-header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    flex-wrap: wrap;
    gap: 0.25rem;
  }

  .experience-company {
    font-weight: 600;
    font-size: 0.95rem;
    color: var(--color-text);
    margin-right: 0.6rem;
  }

  .experience-role {
    font-size: 0.875rem;
    color: var(--color-accent);
  }

  .experience-period {
    font-size: 0.8rem;
    color: var(--color-text-muted);
    white-space: nowrap;
  }

  .experience-desc {
    font-size: 0.9rem;
    color: var(--color-text-muted);
    line-height: 1.65;
    margin: 0;
  }

  .experience-games {
    display: flex;
    gap: 0.4rem;
    flex-wrap: wrap;
    margin-top: 0.25rem;
  }

  .game-tag {
    font-size: 0.75rem;
    font-weight: 500;
    padding: 0.2em 0.65em;
    border-radius: 999px;
    background: rgba(109, 133, 245, 0.12);
    color: var(--color-accent);
  }

  .post-list {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  @media (max-width: 600px) {
    .project-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
